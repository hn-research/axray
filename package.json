{
  "name": "mcp-xray",
  "version": "0.0.0",
  "description": "See what your AI agents can actually do. Discover trustworthy MCP servers, find the risky ones.",
  "bin": { "mcp-xray": "dist/cli.js" },
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "node --test --import tsx ./tests/*.test.ts"
  },
  "keywords": ["mcp", "ai-agents", "security", "trust", "scanner", "agentic"],
  "license": "Apache-2.0",
  "author": "Abhishek Goswami",
  "repository": { "type": "git", "url": "git+https://github.com/REPLACE/mcp-xray.git" },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "boxen": "^8.0.0",
    "commander": "^12.0.0",
    "picocolors": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "files": ["dist", "README.md", "LICENSE"]
}
